module MEF_posicionamento(
  input count_sig,
  input clk,
  input reset,
  output [1:0]tipo_navio,
  output reg complete
);
//--------------------------------------------------- 
  wire [2:0] casas_navio;//contagem de 3 bits;
  reg reset_contador,inc_contador;//Manipular o contador
//-------------------------------------------------------
  //1º- Definição dos estados
  reg[1:0] estado_atual;
  reg[1:0] proximo_estado;
  localparam INSERE_PORTA_AVIAO = 2'b00;
  localparam INSERE_FRAGATA     = 2'b01;
  localparam INSERE_CORVETA     = 2'b10;
  localparam INSERE_SUB         = 2'b11;
//-------------------------------------------------------
  //3º-Bloco Sequêncial
  always @(posedge clk or posedge reset) begin
    if (reset) 
        estado_atual <= INSERE_PORTA_AVIAO;
    else 
        estado_atual <= proximo_estado;
end
//-------------------------------------------------------
  //3º-Lógica Próximo estados
  always@(*) begin
    //Valores base:
    reset_contador = 1'b0;
    inc_contador = 1'b0;
    complete = 1'b0;
    case(estado_atual)
      INSERE_PORTA_AVIAO:
        if(casas_navio==5)begin
          proximo_estado = INSERE_FRAGATA;
          reset_contador = 1'b1;
        end
        else begin
          proximo_estado = INSERE_PORTA_AVIAO;
          inc_contador   = 1'b1;
      end
      INSERE_FRAGATA:
        if(casas_navio == 4)begin
          proximo_estado = INSERE_CORVETA;
          reset_contador = 1'b1;
      end
      else begin
        proximo_estado = INSERE_FRAGATA;
        inc_contador   = 1'b1;
      end
      INSERE_CORVETA:
        if(casas_navio==3)begin
          proximo_estado =INSERE_SUB;
          reset_contador = 1'b1;
        end
        else begin
          proximo_estado = INSERE_CORVETA;
          inc_contador   = 1'b1;
        end
      INSERE_SUB:
        if(casas_navio==2)begin
          proximo_estado = INSERE_PORTA_AVIAO;
          reset_contador = 1'b1;
          complete = 1'b1;
        end
        else begin
          proximo_estado = INSERE_SUB;
          inc_contador   = 1'b1;
        end
      default:
          proximo_estado= INSERE_PORTA_AVIAO;
    endcase
  end
//-------------------------------------------------------
    //Lógica das saídas
    
    contador_navios CONTADOR_UNICO (
    .clk(clk),                       // Precisa passar o clock do sistema
    .incremento(inc_contador),       // Controlado pela FSM
    .reset(reset_contador || reset), // Reenicia a contagem com o rest da MEF principal ou com o do local
    .contagem(casas_navio)           // A saída alimenta o 'casas_navio' usado na FSM
);
    assign tipo_navio = estado_atual;
    
endmodule
    
  
